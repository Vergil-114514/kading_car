#include <assert.h>
#include <math.h>
#include <stdarg.h>
#include <stdio.h>

#include "save_point_mode_host_stubs.h"
#include "save_point_mode.h"

uint16_t IMU_savenum;
float IMU_X[FLASH_IMU_POINT_CAPACITY];
float IMU_Y[FLASH_IMU_POINT_CAPACITY];

static LoraRemoteState_t g_remote;
static TopSpeed_GPS_INS_Output g_navigation;
static TopSpeed_GPS_INS_IMU_Output g_imu;
static TopSpeed_GPS_INS_LocalOdometryOutput g_local_odometry;
static uint32_t g_local_reset_sequence;
static unsigned g_point_save_calls;
static unsigned g_data_save_calls;
static unsigned g_save_order;
static uint8 g_wifi_init_result;
static uint8 g_wifi_socket_result;
static uint32 g_wifi_send_result;
static unsigned g_wifi_init_calls;
static unsigned g_wifi_socket_calls;
static unsigned g_wifi_send_calls;
static unsigned g_wifi_sent_frame_count;
static char g_wifi_sent_frames[8][64];
static unsigned g_printf_line_count;
static char g_printf_lines[16][96];

int save_point_test_printf(const char *format, ...)
{
    va_list arguments;
    int length;

    assert(g_printf_line_count < 16U);
    va_start(arguments, format);
    length = vsnprintf(g_printf_lines[g_printf_line_count],
                       sizeof(g_printf_lines[0]),
                       format,
                       arguments);
    va_end(arguments);
    assert(length > 0);
    assert((unsigned)length < sizeof(g_printf_lines[0]));
    ++g_printf_line_count;
    return length;
}

static void reset_printf_capture(void)
{
    g_printf_line_count = 0U;
    memset(g_printf_lines, 0, sizeof(g_printf_lines));
}

void LoraRemote_GetState(LoraRemoteState_t *state)
{
    *state = g_remote;
}

void TopSpeed_GPS_INS_PortGetOutput(TopSpeed_GPS_INS_Output *output)
{
    *output = g_navigation;
}

void TopSpeed_GPS_INS_PortGetIMUOutput(TopSpeed_GPS_INS_IMU_Output *output)
{
    *output = g_imu;
}

uint32_t TopSpeed_GPS_INS_PortRequestLocalOdometryReset(void)
{
    ++g_local_reset_sequence;
    if(g_local_reset_sequence == 0U) { g_local_reset_sequence = 1U; }
    g_local_odometry.position_m.x = 0.0f;
    g_local_odometry.position_m.y = 0.0f;
    g_local_odometry.relative_yaw_deg = 0.0f;
    g_local_odometry.encoder_speed_mps = 0.0f;
    g_local_odometry.distance_m = 0.0f;
    g_local_odometry.reset_sequence = g_local_reset_sequence;
    g_local_odometry.valid = 0U;
    return g_local_reset_sequence;
}

void TopSpeed_GPS_INS_PortGetLocalOdometryOutput(
    TopSpeed_GPS_INS_LocalOdometryOutput *output)
{
    *output = g_local_odometry;
}

void IMU_POINT_SAVE(void)
{
    ++g_point_save_calls;
    assert(g_save_order == 0U);
    g_save_order = 1U;
}

void DATA_SAVE(void)
{
    ++g_data_save_calls;
    assert(g_save_order == 1U);
    g_save_order = 2U;
}

uint8 wifi_spi_init(char *wifi_ssid, char *pass_word)
{
    ++g_wifi_init_calls;
    assert(strcmp(wifi_ssid, SAVE_POINT_MODE_WIFI_SSID) == 0);
    assert(strcmp(pass_word, SAVE_POINT_MODE_WIFI_PASSWORD) == 0);
    return g_wifi_init_result;
}

uint8 wifi_spi_socket_connect(char *transport_type,
                              char *ip_addr,
                              char *port,
                              char *local_port)
{
    ++g_wifi_socket_calls;
    assert(strcmp(transport_type, "TCP") == 0);
    assert(strcmp(ip_addr, WIFI_SPI_TARGET_IP) == 0);
    assert(strcmp(port, WIFI_SPI_TARGET_PORT) == 0);
    assert(strcmp(local_port, WIFI_SPI_LOCAL_PORT) == 0);
    return g_wifi_socket_result;
}

uint32 wifi_spi_send_buffer(const uint8 *buffer, uint32 length)
{
    ++g_wifi_send_calls;
    if(g_wifi_send_result != 0U)
    {
        return g_wifi_send_result;
    }

    assert(g_wifi_sent_frame_count < 8U);
    assert(length < sizeof(g_wifi_sent_frames[0]));
    memcpy(g_wifi_sent_frames[g_wifi_sent_frame_count], buffer, length);
    g_wifi_sent_frames[g_wifi_sent_frame_count][length] = '\0';
    ++g_wifi_sent_frame_count;
    return 0U;
}

static int nearly_equal(float left, float right)
{
    return fabsf(left - right) < 0.001f;
}

static void release_keys(void)
{
    g_remote.key[SAVE_POINT_MODE_START_KEY_INDEX] = 0U;
    g_remote.key[SAVE_POINT_MODE_STOP_KEY_INDEX] = 0U;
    SavePointMode_5msCallback();
}

static void press_start(void)
{
    g_remote.key[SAVE_POINT_MODE_START_KEY_INDEX] = 1U;
    SavePointMode_5msCallback();
    release_keys();
}

int main(void)
{
    SavePointModeStatus_t status;
    unsigned index;

    memset(&g_remote, 0, sizeof(g_remote));
    memset(&g_navigation, 0, sizeof(g_navigation));
    memset(&g_imu, 0, sizeof(g_imu));
    memset(&g_local_odometry, 0, sizeof(g_local_odometry));
    g_remote.link_ok = 1U;
    SavePointMode_Init();
    SavePointMode_Enter();

    /* Empty RAM must not erase the route already stored in flash. */
    g_remote.key[SAVE_POINT_MODE_START_KEY_INDEX] = 1U;
    g_remote.key[SAVE_POINT_MODE_STOP_KEY_INDEX] = 1U;
    SavePointMode_5msCallback();
    SavePointMode_Task();
    assert(g_point_save_calls == 0U && g_data_save_calls == 0U);
    assert(g_wifi_init_calls == 1U);
    release_keys();
    SavePointMode_Task();
    assert(g_wifi_socket_calls == 1U);

    /* Starting before navigation and IMU are ready is rejected. */
    press_start();
    SavePointMode_GetStatus(&status);
    assert(status.start_rejected != 0U);
    assert(status.point_count == 0U);

    g_navigation.initialized = 1U;
    g_navigation.encoder_valid = 1U;
    g_navigation.position_m.x = 10.0f;
    g_navigation.position_m.y = 20.0f;
    g_imu.valid = 1U;
    g_imu.heading_deg = 90.0f;
    g_local_odometry.initialized = 1U;
    g_local_odometry.heading_valid = 1U;
    g_local_odometry.encoder_valid = 1U;
    g_local_odometry.valid = 1U;
    press_start();

    SavePointMode_GetStatus(&status);
    assert(status.recording != 0U);
    assert(status.point_count == 1U);
    assert(IMU_X[0] == 0.0f && IMU_Y[0] == 0.0f);
    assert(status.relative_yaw_deg == 0.0f);
    assert(status.wifi_session == 1U);

    SavePointMode_Task();
    assert(g_wifi_sent_frame_count == 1U);
    assert(strcmp(g_wifi_sent_frames[0], "SP,1,0,0.00,0.00\r\n") == 0);
    SavePointMode_GetStatus(&status);
    assert(status.wifi_connected != 0U);
    assert(status.wifi_sent_count == 1U);

    /* Ten 5 ms samples at 10 m/s accumulate exactly 0.5 m. */
    g_navigation.position_m.x = 10.5f;
    g_navigation.encoder_speed_mps = 10.0f;
    g_local_odometry.position_m.y = 0.5f;
    g_local_odometry.encoder_speed_mps = 10.0f;
    for(index = 0U; index < 10U; ++index)
    {
        g_local_odometry.distance_m += 0.05f;
        SavePointMode_5msCallback();
    }
    assert(IMU_savenum == 2U);
    assert(nearly_equal(IMU_X[1], 0.0f));
    assert(nearly_equal(IMU_Y[1], 0.5f));

    /* A failed send keeps the point pending and retries it after reconnect. */
    g_wifi_send_result = 1U;
    SavePointMode_Task();
    SavePointMode_GetStatus(&status);
    assert(g_wifi_send_calls == 2U);
    assert(g_wifi_sent_frame_count == 1U);
    assert(status.wifi_connected == 0U);
    assert(status.wifi_sent_count == 1U);
    assert(status.wifi_error_count == 1U);
    for(index = 0U; index < SAVE_POINT_MODE_WIFI_RETRY_TICKS; ++index)
    {
        SavePointMode_100msTask();
    }
    g_wifi_send_result = 0U;
    SavePointMode_Task();
    assert(g_wifi_socket_calls == 2U);
    SavePointMode_Task();
    assert(g_wifi_sent_frame_count == 2U);
    assert(strcmp(g_wifi_sent_frames[1], "SP,1,1,0.00,0.50\r\n") == 0);

    /* The local frame follows launch yaw and yaw wraps to [-180, 180). */
    g_navigation.position_m.y = 20.5f;
    g_navigation.encoder_speed_mps = 0.0f;
    g_imu.heading_deg = -170.0f;
    g_local_odometry.position_m.x = -0.5f;
    g_local_odometry.position_m.y = 0.5f;
    g_local_odometry.relative_yaw_deg = 100.0f;
    g_local_odometry.encoder_speed_mps = 0.0f;
    SavePointMode_5msCallback();
    SavePointMode_GetStatus(&status);
    assert(nearly_equal(status.local_x_m, -0.5f));
    assert(nearly_equal(status.local_y_m, 0.5f));
    assert(nearly_equal(status.relative_yaw_deg, 100.0f));

    reset_printf_capture();
    g_remote.key[SAVE_POINT_MODE_STOP_KEY_INDEX] = 1U;
    SavePointMode_5msCallback();
    SavePointMode_GetStatus(&status);
    assert(status.recording == 0U);
    assert(status.point_count == 3U);
    assert(nearly_equal(IMU_X[2], -0.5f));
    assert(nearly_equal(IMU_Y[2], 0.5f));
    assert(nearly_equal(status.distance_since_last_point_m, 0.0f));

    /* CPU0 task prints every stored point, one line per call. */
    for(index = 0U; index < status.point_count + 2U; ++index)
    {
        SavePointMode_Task();
    }
    assert(g_printf_line_count == 5U);
    assert(strcmp(g_printf_lines[0], "SAVE_POINT_BEGIN,3\r\n") == 0);
    assert(strcmp(g_printf_lines[1],
                  "SAVE_POINT,0,0.000,0.000\r\n") == 0);
    assert(strcmp(g_printf_lines[2],
                  "SAVE_POINT,1,0.000,0.500\r\n") == 0);
    assert(strcmp(g_printf_lines[3],
                  "SAVE_POINT,2,-0.500,0.500\r\n") == 0);
    assert(strcmp(g_printf_lines[4], "SAVE_POINT_END,3\r\n") == 0);
    assert(g_wifi_sent_frame_count == 3U);
    assert(strcmp(g_wifi_sent_frames[2],
                  "SP,1,2,-0.50,0.50\r\n") == 0);

    g_navigation.encoder_speed_mps = 20.0f;
    g_local_odometry.encoder_speed_mps = 20.0f;
    for(index = 0U; index < 10U; ++index)
    {
        SavePointMode_5msCallback();
    }
    assert(IMU_savenum == 3U);

    /* Adding S3 while S4 is held forms the combination and saves once. */
    g_remote.key[SAVE_POINT_MODE_START_KEY_INDEX] = 1U;
    SavePointMode_5msCallback();
    SavePointMode_Task();
    assert(g_point_save_calls == 1U && g_data_save_calls == 1U);
    assert(g_save_order == 2U);
    SavePointMode_5msCallback();
    SavePointMode_Task();
    assert(g_point_save_calls == 1U && g_data_save_calls == 1U);
    SavePointMode_GetStatus(&status);
    assert(status.flash_saved != 0U);
    release_keys();

    /* A new S3 session replaces RAM data and stops safely at capacity. */
    g_navigation.position_m.x = 0.0f;
    g_navigation.position_m.y = 0.0f;
    g_navigation.encoder_speed_mps = 20.0f;
    g_imu.heading_deg = 0.0f;
    press_start();
    SavePointMode_Task();
    assert(g_wifi_sent_frame_count == 4U);
    assert(strcmp(g_wifi_sent_frames[3], "SP,2,0,0.00,0.00\r\n") == 0);

    /* Signed coordinates spanning the stated 30 m by 40 m field fit the frame. */
    g_navigation.position_m.x = -30.0f;
    g_navigation.position_m.y = 40.0f;
    g_navigation.encoder_speed_mps = 100.0f;
    g_local_odometry.position_m.x = -30.0f;
    g_local_odometry.position_m.y = 40.0f;
    g_local_odometry.encoder_speed_mps = 100.0f;
    g_local_odometry.distance_m += 0.5f;
    SavePointMode_5msCallback();
    SavePointMode_Task();
    assert(g_wifi_sent_frame_count == 5U);
    assert(strcmp(g_wifi_sent_frames[4],
                  "SP,2,1,-30.00,40.00\r\n") == 0);

    g_navigation.encoder_speed_mps = 20.0f;
    g_local_odometry.encoder_speed_mps = 20.0f;
    for(index = 0U;
        index < (FLASH_IMU_POINT_CAPACITY - 1U) * 5U;
        ++index)
    {
        g_local_odometry.distance_m += 0.1f;
        SavePointMode_5msCallback();
    }
    SavePointMode_GetStatus(&status);
    assert(status.point_count == FLASH_IMU_POINT_CAPACITY);
    assert(status.recording == 0U);
    assert(status.full != 0U);
    assert(status.wifi_session == 2U);

    /* At capacity, S3 replaces the last sample with the true endpoint. */
    g_navigation.position_m.x = -29.75f;
    g_navigation.position_m.y = 39.75f;
    g_local_odometry.position_m.x = -29.75f;
    g_local_odometry.position_m.y = 39.75f;
    g_remote.key[SAVE_POINT_MODE_STOP_KEY_INDEX] = 1U;
    SavePointMode_5msCallback();
    SavePointMode_GetStatus(&status);
    assert(status.point_count == FLASH_IMU_POINT_CAPACITY);
    assert(nearly_equal(status.last_point_x_m, -29.75f));
    assert(nearly_equal(status.last_point_y_m, 39.75f));

    /* Pressing S3 and S4 together also finalizes the short tail before save. */
    release_keys();
    g_navigation.position_m.x = 5.0f;
    g_navigation.position_m.y = 5.0f;
    g_navigation.encoder_speed_mps = 0.0f;
    press_start();
    g_navigation.position_m.x = 5.2f;
    g_navigation.position_m.y = 5.1f;
    g_local_odometry.position_m.x = 0.2f;
    g_local_odometry.position_m.y = 0.1f;
    g_remote.key[SAVE_POINT_MODE_START_KEY_INDEX] = 1U;
    g_remote.key[SAVE_POINT_MODE_STOP_KEY_INDEX] = 1U;
    SavePointMode_5msCallback();
    SavePointMode_GetStatus(&status);
    assert(status.point_count == 2U);
    assert(nearly_equal(status.last_point_x_m, 0.2f));
    assert(nearly_equal(status.last_point_y_m, 0.1f));
    assert(status.flash_save_pending != 0U);
    g_save_order = 0U;
    SavePointMode_Task();
    assert(g_point_save_calls == 2U && g_data_save_calls == 2U);

    SavePointMode_Exit();
    puts("save_point_mode_test: PASS");
    return 0;
}
