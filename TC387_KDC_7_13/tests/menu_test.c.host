{
    return "GPS_INS";
}

void gpio_init(int pin, int dir, uint8_t level, int mode)
{
    (void)pin; (void)dir; (void)level; (void)mode;
}
uint8_t gpio_get_level(int pin) { return (pin == P33_4) ? g_p33_4 : g_p33_5; }
void ips200_init(int type) { (void)type; }
void ips200_set_dir(int dir) { (void)dir; }
void ips200_set_font(int font) { (void)font; }
void ips200_set_color(uint16_t pen, uint16_t background)
{ (void)pen; (void)background; }
void ips200_clear(void)
{
    uint8_t row;
    memset(g_displayed_float_valid, 0, sizeof(g_displayed_float_valid));
    memset(g_displayed_uint_valid, 0, sizeof(g_displayed_uint_valid));
    for(row = 0U; row < MENU_ROW_COUNT; ++row)
    {
        memset(g_screen[row], ' ', MENU_COLUMN_COUNT);
        g_screen[row][MENU_COLUMN_COUNT] = '\0';
    }
}
void ips200_show_string(uint16_t x, uint16_t y, const char text[])
{
    uint16_t row = y / MENU_FONT_HEIGHT;
    uint16_t column = x / MENU_FONT_WIDTH;

    if((row >= MENU_ROW_COUNT) || (column >= MENU_COLUMN_COUNT)) { return; }
    while((*text != '\0') && (column < MENU_COLUMN_COUNT))
    {
        g_screen[row][column++] = *text++;
    }
}
void ips200_show_int(uint16_t x, uint16_t y, int32_t value, uint8_t digits)
{ (void)x; (void)y; (void)value; (void)digits; }
void ips200_show_uint(uint16_t x, uint16_t y, uint32_t value, uint8_t digits)
{
    uint16_t row = y / MENU_FONT_HEIGHT;

    (void)x;
    (void)digits;
    if(row < MENU_ROW_COUNT)
    {
        g_displayed_uint[row] = value;
        g_displayed_uint_valid[row] = 1U;
    }
}
void ips200_show_float(uint16_t x, uint16_t y, double value,
                       uint8_t digits, uint8_t decimals)
{
    uint16_t row = y / MENU_FONT_HEIGHT;

    (void)x;
    (void)digits;
    (void)decimals;
    if(row < MENU_ROW_COUNT)
    {
        g_displayed_float[row] = value;
        g_displayed_float_valid[row] = 1U;
    }
}

static void test_mode_enter(void) { ++g_test_enter_count; }

static void change_board_pins_during_runtime(uint8_t p33_5, uint8_t p33_4)
{
    unsigned i;
    g_p33_5 = p33_5;
    g_p33_4 = p33_4;
    /* Runtime samples must not change the mode latched by Menu_init(). */
    for(i = 0U; i < 4U; ++i) { Control_5msCallback(); }
    Menu_Task();
}

static void send_remote_frame(uint8_t active_switch,
                              int16_t steer,
                              int16_t throttle,
                              int8_t pressed_key)
{
    memset(&g_next_frame, 0, sizeof(g_next_frame));
    g_next_frame.head = 0xA3U;
    g_next_frame.joystick[0] = steer;
    g_next_frame.joystick[3] = throttle;
    if(active_switch < 4U) { g_next_frame.switch_key[active_switch] = 1U; }
    if((pressed_key >= 0) && (pressed_key < 4))
    {
        g_next_frame.key[(uint8_t)pressed_key] = 1U;
    }
    ++g_frame_sequence;
    g_frame_ready = 1U;
}

static void advance_startup_page(void)
{
    unsigned ticks = MENU_STARTUP_PAGE_HOLD_MS / 100U;
    unsigned index;

    for(index = 0U; index < ticks; ++index) { Menu_100msTask(); }
    Menu_Task();
    Menu_Display();
}

int main(void)
{
    MenuModeHooks_t hooks = {test_mode_enter, 0, 0};
    MenuPeripheralStatus_t init_status = {1U, 1U, 1U, 1U,
                                           1U, 1U, 0U, 0U};
    TestModeStatus_t status;
    RemoteModeStatus_t remote_status;
    ACKERMANN_PID_GAIN before;
    ACKERMANN_PID_GAIN after;
    unsigned i;

    Menu_RegisterModeHooks(CAR_MODE_TEST, &hooks);
    /* Boot with S6=10 (P33.5 active, P33.4 inactive): TEST mode. */
    g_p33_5 = 0U;
    g_p33_4 = 1U;
    g_navigation.initialized = 1U;
    g_navigation.valid = 1U;
    g_navigation.position_m.x = 12.5f;
    g_navigation.position_m.y = -3.0f;
    g_navigation.speed_source = TOPSPEED_GPS_INS_SPEED_ENCODER;
    g_imu.roll_deg = 1.5f;
    g_imu.pitch_deg = -2.5f;
    g_imu.heading_deg = 123.4f;
    g_gps.enabled = 1U;
    Menu_SetPeripheralInitStatus(&init_status);
    Menu_init();
    Menu_Task();
    Menu_Display();
    assert(Menu_GetMode() == CAR_MODE_TEST);
    assert(g_test_enter_count == 1U);
    assert(g_screen[MENU_CURSOR_ROW][0] == '-');
    assert(g_screen[MENU_CURSOR_ROW][1] == '>');
    assert(strstr(g_screen[MENU_CURSOR_ROW], "SYSTEM / INS STATUS") != 0);
    assert(strstr(g_screen[8], "TEST") != 0);
    assert(strstr(g_screen[9], "GPS_INS") != 0);

    advance_startup_page();
    assert(strstr(g_screen[MENU_CURSOR_ROW], "MOTOR PID TEST") != 0);
    assert(strstr(g_screen[2], "LOST") != 0);

    /* Changing S6 to 11 after initialization must be ignored. */
    change_board_pins_during_runtime(0U, 0U);
    assert(Menu_GetMode() == CAR_MODE_TEST);

    Control_5msCallback();
    TestMode_GetStatus(&status);
    assert(status.lora_link_ok == 0U);
    assert(g_left_enable == 0U && g_right_enable == 0U && g_steer_enable == 0U);

    send_remote_frame(0U, 1900, 0, -1);
    Control_5msCallback();
    assert(TestMode_GetChannel() == TEST_MODE_CHANNEL_STEERING);
    assert(g_left_enable == 0U && g_right_enable == 0U && g_steer_enable == 1U);
    TestMode_GetStatus(&status);
    assert(status.steering_target_deg == 110.0f);

    assert(TestMode_GetPidGains(TEST_MODE_CHANNEL_STEERING, &before) == 0U);
    send_remote_frame(0U, 0, 0, 0);
    Control_5msCallback();
    TestMode_GetStatus(&status);
    assert(status.selected_term == TEST_MODE_PID_KI);
    send_remote_frame(0U, 0, 0, -1);
    Control_5msCallback();
    send_remote_frame(0U, 0, 0, 3);
    Control_5msCallback();
    assert(TestMode_GetPidGains(TEST_MODE_CHANNEL_STEERING, &after) == 0U);
    assert(after.ki > before.ki);

    memset(&g_next_frame, 0, sizeof(g_next_frame));
    g_next_frame.switch_key[0] = 1U;
    g_next_frame.switch_key[1] = 1U;
    ++g_frame_sequence;
    g_frame_ready = 1U;
    Control_5msCallback();
    assert(TestMode_GetChannel() == TEST_MODE_CHANNEL_SWITCH_CONFLICT);
    assert(g_left_enable == 0U && g_right_enable == 0U && g_steer_enable == 0U);

    send_remote_frame(1U, 0, 1900, -1);
    Control_5msCallback();
    assert(TestMode_GetChannel() == TEST_MODE_CHANNEL_LEFT_REAR);
    assert(g_left_enable == 1U && g_right_enable == 0U && g_steer_enable == 0U);
    assert(g_left_pwm > 0.0f && g_right_pwm == 0.0f);

    for(i = 0U; i < 61U; ++i) { Control_5msCallback(); }
    TestMode_GetStatus(&status);
    assert(status.lora_link_ok == 0U);
    assert(g_left_enable == 0U && g_right_enable == 0U && g_steer_enable == 0U);

    g_servo_angle = 90.0f;
    send_remote_frame(3U, 950, 380, -1);
    Control_5msCallback();
    assert(TestMode_GetChannel() == TEST_MODE_CHANNEL_DRIVE);
    assert(g_left_enable == 1U && g_right_enable == 1U && g_steer_enable == 1U);
    TestMode_GetStatus(&status);
    assert(status.target_a == status.target_b);
    for(i = 0U; i < 30U; ++i) { Control_5msCallback(); }
    TestMode_GetStatus(&status);
    assert(status.target_a < status.target_b);

    /* Simulate a reset with S6=11; only the new initialization reads it. */
    g_p33_5 = 0U;
    g_p33_4 = 0U;
    Menu_init();
    Menu_Task();
    Menu_Display();
    assert(Menu_GetMode() == CAR_MODE_REMOTE);
    assert(strstr(g_screen[MENU_CURSOR_ROW], "SYSTEM / INS STATUS") != 0);
    advance_startup_page();
    assert(strstr(g_screen[MENU_CURSOR_ROW], "REMOTE DATA / PAGE 2") != 0);
    assert(strstr(g_screen[12], "IMU ROLL") != 0);
    assert(strstr(g_screen[13], "IMU PITCH") != 0);
    assert(strstr(g_screen[14], "IMU HEADING") != 0);
    assert(strstr(g_screen[15], "CAR X") != 0);
    assert(strstr(g_screen[16], "CAR Y") != 0);
    assert(strstr(g_screen[12], "GYRO") == 0);
    assert(g_displayed_float_valid[12] != 0U);
    assert(g_displayed_float_valid[13] != 0U);
    assert(g_displayed_float_valid[14] != 0U);
    assert(g_displayed_float_valid[15] != 0U);
    assert(g_displayed_float_valid[16] != 0U);
    assert(g_displayed_float[12] == (double)g_imu.roll_deg);
    assert(g_displayed_float[13] == (double)g_imu.pitch_deg);
    assert(g_displayed_float[14] == (double)g_imu.heading_deg);
    assert(g_displayed_float[15] == (double)g_navigation.position_m.x);
    assert(g_displayed_float[16] == (double)g_navigation.position_m.y);
    /* No remote switch means S5=0: equal open-loop rear PWM. */
    send_remote_frame(4U, 950, 1900, -1);
    Control_5msCallback();
    assert(g_left_enable == 1U && g_right_enable == 1U && g_steer_enable == 1U);
    assert(g_left_pwm == 8000.0f && g_right_pwm == 8000.0f);
    RemoteMode_GetStatus(&remote_status);
    assert(remote_status.rear_closed_loop == 0U);
    assert(remote_status.throttle_input == 1.0f);
    assert(remote_status.left_target_mps == 0.0f);

    /* S5=1 must not run the closed loops without valid rear encoders. */
    g_telemetry.encoder_valid = 0U;
    send_remote_frame(0U, 950, 1900, -1);
    Control_5msCallback();
    RemoteMode_GetStatus(&remote_status);
    assert(remote_status.rear_closed_loop == 1U);
    assert(g_left_pwm == 0.0f && g_right_pwm == 0.0f);
    assert(remote_status.left_target_mps == 0.0f);
    assert(remote_status.right_target_mps == 0.0f);

    /* At straight-ahead feedback, a new steering command must not create
     * differential speed before the steering mechanism actually moves. */
    g_telemetry.encoder_valid = 1U;
    g_telemetry.left_measured_mps = 0.0f;
    g_telemetry.right_measured_mps = 0.0f;
    g_servo_angle = 90.0f;
    send_remote_frame(0U, 950, 1900, -1);
    Control_5msCallback();
    RemoteMode_GetStatus(&remote_status);
    assert(remote_status.left_target_mps > 0.0f);
    assert(remote_status.left_target_mps == remote_status.right_target_mps);
    assert(g_left_pwm == g_right_pwm);

    /* Subsequent cycles see the measured steering move right and apply
     * progressively larger differential targets. */
    for(i = 0U; i < 20U; ++i) { Control_5msCallback(); }
    RemoteMode_GetStatus(&remote_status);
    assert(remote_status.left_target_mps < remote_status.right_target_mps);
    assert(remote_status.right_target_mps <= 3.0f);
    assert(g_left_pwm > 0.0f && g_right_pwm > g_left_pwm);

    /* Returning S5 to 0 restores direct reverse PWM and clears PID targets. */
    send_remote_frame(4U, 0, -1900, -1);
    Control_5msCallback();
    assert(g_left_pwm == -8000.0f && g_right_pwm == -8000.0f);
    RemoteMode_GetStatus(&remote_status);
    assert(remote_status.rear_closed_loop == 0U);
    assert(remote_status.left_target_mps == 0.0f);
    assert(g_stop_count > 0U);

    /* S6=01 selects SAVE POINT, retaining remote driving while recording. */
    g_p33_5 = 1U;
    g_p33_4 = 0U;
    memset(&g_save_point_status, 0, sizeof(g_save_point_status));
    g_save_point_status.point_count = 17U;
    g_save_point_status.local_x_m = 12.34f;
    g_save_point_status.local_y_m = -5.67f;
    g_save_point_status.last_point_x_m = 12.0f;
    g_save_point_status.last_point_y_m = -5.5f;
    g_save_point_status.relative_yaw_deg = 8.5f;
    g_save_point_status.distance_since_last_point_m = 0.2f;
    g_save_point_status.wifi_sent_count = 17U;
    g_save_point_status.recording = 1U;
    g_save_point_status.wifi_initialized = 1U;
    g_save_point_status.wifi_connected = 1U;
    i = g_save_point_init_calls;
    Menu_init();
    assert(g_save_point_init_calls == i + 1U);
    assert(g_save_point_exit_calls > 0U);
    i = g_save_point_enter_calls;
    Menu_Task();
    assert(Menu_GetMode() == CAR_MODE_SAVE_POINT);
    assert(g_save_point_enter_calls == i + 1U);
    assert(g_save_point_task_calls > 0U);
    send_remote_frame(4U, 975, 1900, -1);
    i = g_save_point_5ms_calls;
    Control_5msCallback();
    assert(g_save_point_5ms_calls == i + 1U);
    assert(g_left_enable == 1U && g_right_enable == 1U && g_steer_enable == 1U);
    assert(g_left_pwm == 8000.0f && g_right_pwm == 8000.0f);
    RemoteMode_GetStatus(&remote_status);
    assert(remote_status.throttle_input == 1.0f);
    assert(remote_status.steering_input == 0.5f);
    i = g_save_point_100ms_calls;
    advance_startup_page();
    assert(g_save_point_100ms_calls == i +
           (MENU_STARTUP_PAGE_HOLD_MS / 100U));
    assert(menu.page == MENU_PAGE_SAVE_POINT);
    assert(strstr(g_screen[MENU_CURSOR_ROW], "SAVE POINT MODE") != 0);
    assert(strstr(g_screen[2], "RECORDING") != 0);
    assert(strstr(g_screen[3], "/1024") != 0);
    assert(strstr(g_screen[11], "OK") != 0);
    assert(strstr(g_screen[12], "OK") != 0);
    assert(strstr(g_screen[16], "LX: STEER") != 0);
    assert(strstr(g_screen[17], "S5: 0 OPEN / 1 ACK DIFF") != 0);
    assert(strstr(g_screen[18], "S3: START / RESTART") != 0);
    assert(strstr(g_screen[19], "S3+S4: SAVE") != 0);
    assert(g_displayed_uint_valid[3] != 0U);
    assert(g_displayed_uint[3] == 17U);
    assert(g_displayed_uint[13] == 17U);
    assert(g_displayed_float[4] == (double)g_save_point_status.local_x_m);
    assert(g_displayed_float[5] == (double)g_save_point_status.local_y_m);
    assert(g_displayed_float[6] == (double)g_save_point_status.last_point_x_m);
    assert(g_displayed_float[7] == (double)g_save_point_status.last_point_y_m);
    assert(g_displayed_float[8] ==
           (double)g_save_point_status.relative_yaw_deg);
    assert(fabs(g_displayed_float[9] - 0.3) < 0.001);

    /* S6=00 selects reverse TRACK without entering any other mode handler. */
    g_p33_5 = 1U;
    g_p33_4 = 1U;
    i = g_reverse_track_init_calls;
    Menu_init();
    assert(g_reverse_track_init_calls == i + 1U);
    assert(g_reverse_track_exit_calls > 0U);
    i = g_reverse_track_enter_calls;
    Menu_Task();
    assert(Menu_GetMode() == CAR_MODE_TRACK);
    assert(g_reverse_track_enter_calls == i + 1U);
    assert(g_reverse_track_task_calls > 0U);
    i = g_reverse_track_5ms_calls;
    Control_5msCallback();
    assert(g_reverse_track_5ms_calls == i + 1U);

    puts("menu_lora_pid_test: PASS");
    return 0;
}
