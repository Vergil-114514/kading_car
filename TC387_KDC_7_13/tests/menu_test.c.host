void Ackermann_control_enable(uint8_t enable) { (void)enable; }
void Ackermann_port_5ms_callback(void) { ++g_ackermann_port_5ms_count; }
void Ackermann_get_default_config(ACKERMANN_CONTROL_CONFIG *config)
{
    memset(config, 0, sizeof(*config));
    config->wheelbase_m = 0.58f;
    config->track_width_m = 0.60f;
    config->max_steering_angle_rad = 30.0f * ACKERMANN_DEG_TO_RAD;
    config->max_vehicle_speed_mps = 3.0f;
    config->max_wheel_speed_mps = 3.0f;
    config->left_motor_sign = 1.0f;
    config->right_motor_sign = 1.0f;
    config->steering_center_encoder_deg = 90.0f;
    config->steering_encoder_deg_per_road_deg = 1.0f;
    config->steering_sign = 1.0f;
    config->steering_position_pid.kp = 60.0f;
    config->steering_position_pid.ki = 1.0f;
    config->steering_position_pid.kd = 0.5f;
    config->steering_position_pid.integral_limit = 400.0f;
    config->steering_position_pid.output_limit = 2000.0f;
    config->steering_position_pid.deadband = 0.3f;
    config->left_speed_pid.kp = 2750.0f;
    config->left_speed_pid.ki = 600.0f;
    config->left_speed_pid.integral_limit = 2000.0f;
    config->left_speed_pid.output_limit = 2000.0f;
    config->left_speed_pid.deadband = 0.01f;
    config->right_speed_pid = config->left_speed_pid;
    g_left_gain = config->left_speed_pid;
    g_right_gain = config->right_speed_pid;
}
void Ackermann_get_telemetry(ACKERMANN_CONTROL_TELEMETRY *telemetry)
{
    *telemetry = g_telemetry;
}
float Ackermann_get_steering_center(void) { return 90.0f; }
void Ackermann_electronic_differential(float center_speed_mps,
                                       float steering_angle_rad,
                                       const ACKERMANN_CONTROL_CONFIG *config,
                                       float *left_speed_mps,
                                       float *right_speed_mps)
{
    float correction = center_speed_mps * steering_angle_rad
                     * config->track_width_m / (2.0f * config->wheelbase_m);
    *left_speed_mps = center_speed_mps - correction;
    *right_speed_mps = center_speed_mps + correction;
}
float Ackermann_road_steering_to_encoder_angle_deg(
    float road_steering_rad,
    const ACKERMANN_CONTROL_CONFIG *config)
{
    if(road_steering_rad > config->max_steering_angle_rad)
    {
        road_steering_rad = config->max_steering_angle_rad;
    }
    if(road_steering_rad < -config->max_steering_angle_rad)
    {
        road_steering_rad = -config->max_steering_angle_rad;
    }
    return config->steering_center_encoder_deg
         + config->steering_sign * road_steering_rad
         / ACKERMANN_DEG_TO_RAD
         * config->steering_encoder_deg_per_road_deg;
}
float Ackermann_encoder_angle_to_road_steering_rad(
    float encoder_angle_deg,
    const ACKERMANN_CONTROL_CONFIG *config)
{
    float road_steering_rad =
        (encoder_angle_deg - config->steering_center_encoder_deg)
        / (config->steering_sign
         * config->steering_encoder_deg_per_road_deg)
        * ACKERMANN_DEG_TO_RAD;

    if(road_steering_rad > config->max_steering_angle_rad)
    {
        road_steering_rad = config->max_steering_angle_rad;
    }
    if(road_steering_rad < -config->max_steering_angle_rad)
    {
        road_steering_rad = -config->max_steering_angle_rad;
    }
    return road_steering_rad;
}
void Ackermann_set_rear_speed_pid_gains(const ACKERMANN_PID_GAIN *left_gain,
                                        const ACKERMANN_PID_GAIN *right_gain)
{
    if(left_gain != 0) { g_left_gain = *left_gain; }
    if(right_gain != 0) { g_right_gain = *right_gain; }
}
void Ackermann_get_rear_speed_pid_gains(ACKERMANN_PID_GAIN *left_gain,
                                        ACKERMANN_PID_GAIN *right_gain)
{
    if(left_gain != 0) { *left_gain = g_left_gain; }
    if(right_gain != 0) { *right_gain = g_right_gain; }
}

void Motor_set_pwm(float left_pwm, float right_pwm)
{
    g_left_pwm = left_pwm;
    g_right_pwm = right_pwm;
}
void Motor_set_rear_speed_pid_gains(const MOTOR_PID_GAIN *left_gain,
                                    const MOTOR_PID_GAIN *right_gain)
{
    if(left_gain != 0) { g_left_gain = *left_gain; }
    if(right_gain != 0) { g_right_gain = *right_gain; }
}
void Motor_get_rear_speed_pid_gains(MOTOR_PID_GAIN *left_gain,
                                    MOTOR_PID_GAIN *right_gain)
{
    if(left_gain != 0) { *left_gain = g_left_gain; }
    if(right_gain != 0) { *right_gain = g_right_gain; }
}
void Motor_rear_speed_pid_reset(void)
{
    memset(&g_left_motor_status, 0, sizeof(g_left_motor_status));
    memset(&g_right_motor_status, 0, sizeof(g_right_motor_status));
}
static float mock_motor_rear_update(const MOTOR_REAR_SPEED_INPUT *input,
                                    const MOTOR_PID_GAIN *gain,
                                    MOTOR_REAR_SPEED_STATUS *status,
                                    uint8_t allow_active_braking)
{
    float pwm;
    if(input == 0)
    {
        memset(status, 0, sizeof(*status));
        return 0.0f;
    }
    status->target_mps = input->target_mps;
    status->measured_mps = input->measured_mps;
    status->error_mps = input->target_mps - input->measured_mps;
    if(input->enabled == 0U)
    {
        status->pwm = 0.0f;
        return 0.0f;
    }
    pwm = gain->kp * status->error_mps + input->feedforward_pwm;
    if((input->pwm_limit > 0.0f) && (pwm > input->pwm_limit))
    {
        pwm = input->pwm_limit;
    }
    if((input->pwm_limit > 0.0f) && (pwm < -input->pwm_limit))
    {
        pwm = -input->pwm_limit;
    }
    if((allow_active_braking == 0U)
    && (((input->target_mps > 0.0f) && (pwm < 0.0f))
     || ((input->target_mps < 0.0f) && (pwm > 0.0f))))
    {
        pwm = 0.0f;
    }
    status->pwm = pwm * ((input->output_sign < 0.0f) ? -1.0f : 1.0f);
    return status->pwm;
}
void Motor_rear_speed_control(const MOTOR_REAR_SPEED_INPUT *left,
                              const MOTOR_REAR_SPEED_INPUT *right,
                              uint8_t allow_active_braking)
{
    g_left_pwm = mock_motor_rear_update(left, &g_left_gain,
                                        &g_left_motor_status,
                                        allow_active_braking);
    g_right_pwm = mock_motor_rear_update(right, &g_right_gain,
                                         &g_right_motor_status,
                                         allow_active_braking);
}
void Motor_get_rear_speed_status(MOTOR_REAR_SPEED_STATUS *left_status,
                                 MOTOR_REAR_SPEED_STATUS *right_status)
{
    if(left_status != 0) { *left_status = g_left_motor_status; }
    if(right_status != 0) { *right_status = g_right_motor_status; }
}
void Motor_enable_channels(uint8_t left, uint8_t right, uint8_t steering)
{
    g_left_enable = left;
    g_right_enable = right;
    g_steer_enable = steering;
}
void Motor_stop_all(void)
{
    g_left_pwm = 0.0f;
    g_right_pwm = 0.0f;
    g_left_enable = 0U;
    g_right_enable = 0U;
    g_steer_enable = 0U;
    ++g_stop_count;
}
void Servo_pid_reset(void) { servo_position_pid.state.output = 0.0f; }
void Servo_set_position_pid_gain(const MOTOR_PID_GAIN *gain)
{
    servo_position_pid.gain = *gain;
}
void Servo_set_angle(float angle_deg) { servo_duty.motor_speed = angle_deg; }
void Servo_position_control(MOTOR_DUTY *duty)
{
    float error = duty->motor_speed - g_servo_angle;
    servo_position_pid.state.output = error * servo_position_pid.gain.kp;
    g_servo_angle += error * 0.1f;
}
float Servo_get_angle(void) { return g_servo_angle; }

uint8_t lora3a22_get_snapshot(lora3a22_uart_transfer_dat_struct *snapshot,
                              uint32 *sequence)
{
    if(g_frame_ready == 0U)
    {
        return 0U;
    }
    *snapshot = g_next_frame;
    if(sequence != 0) { *sequence = g_frame_sequence; }
    g_frame_ready = 0U;
    return 1U;
}
void lora3a22_init(void) {}
void lora3a22_5ms_callback(void) {}

